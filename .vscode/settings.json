{
  // Biome を既定のフォーマッターとして使用
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnSave": true,

  // 言語別に Biome を明示指定
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[css]": {
    "editor.defaultFormatter": "biomejs.biome"
  },

  // Biome の lint 自動修正をファイル保存時に適用
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "explicit"
  }
}
